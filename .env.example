# V3 independent database. Use a Neon/Supabase/Vercel Postgres connection string in production.
DATABASE_URL=

# Real V2 service endpoint. If absent, V3 calls its built-in mock V2 HTTP routes for exam/demo review.
V2_API_BASE_URL=
V2_API_KEY=demo-v2-key

# Required when V2_API_BASE_URL is empty on Vercel, so server-side calls can reach this app's mock V2 routes.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional shared secret for Vercel Cron hitting /api/jobs/run.
CRON_SECRET=
